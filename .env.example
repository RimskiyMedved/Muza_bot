# ─── Авито-поллер (тюнинг, опционально) ──────────────────────────────────────
# AVITO_POLL_INTERVAL=20                  # секунды между циклами
# AVITO_POLL_STALE_CHECK_EVERY=2          # раз в N циклов проверяем зависшие чаты
# AVITO_POLL_BROAD_CHATS_EVERY=3          # раз в N циклов запрашиваем все чаты
# AVITO_POLL_BROAD_CHATS_LIMIT=10         # сколько чатов в широком запросе
# AVITO_POLL_MESSAGES_LIMIT=100           # лимит сообщений при получении истории
# AVITO_POLL_MAX_INBOUND_BURST=15         # защита от лавины входящих
# AVITO_POLL_RECOVERY_PENDING_LIMIT=3     # лимит восстановления pending-чатов

# ─── Мониторинг / health ──────────────────────────────────────────────────────
